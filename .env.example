# Database (Supabase Postgres connection string)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres"

# Internal API Key (used for X-API-Key header authentication on protected endpoints)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTERNAL_API_KEY=

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=

# Telegram Webhook Secret (set this AND register it with Telegram via setWebhook?secret_token=...)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=

# X (Twitter) Username for timeline scraping
X_USERNAME=

# HMAC secret for signing edit/feedback URLs
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET=

# App config
BASE_URL="https://your-app.up.railway.app"
PORT=3000

# Google Gemini API Key
GOOGLE_API_KEY=

# n8n webhook URL for draft-ready notifications
N8N_WEBHOOK_URL=
