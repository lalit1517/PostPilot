# ---- DATABASE (required) ----
# Supabase transaction pooler URL. connection_limit=1 is INTENTIONAL.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=30&tcp_keepalives_idle=60&tcp_keepalives_interval=10&tcp_keepalives_count=5&connection_limit=1&pool_timeout=60"
# Session pooler (port 5432) — used for Prisma migrations only.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"
# Optional — for Grafana dashboards.
GRAFANA_DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# ---- LLM (required) ----
GOOGLE_API_KEY=""

# ---- SECURITY (required) ----
INTERNAL_API_KEY=""
HMAC_SECRET=""
TELEGRAM_WEBHOOK_SECRET=""

# ---- TELEGRAM (required for notifications) ----
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ---- X / TWITTER (required for scraping) ----
# Must match OWNER_PROFILE.username in src/config/ownerProfile.ts.
X_USERNAME="your_handle"

# ---- APP ----
BASE_URL="https://your-app.onrender.com"
PORT=3000
N8N_WEBHOOK_URL=""

# ---- GRAFANA ----
GRAFANA_URL=""
GRAFANA_API_KEY=""
