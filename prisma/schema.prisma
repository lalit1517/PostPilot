generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tweet {
  id             String         @id @default(uuid())
  original_topic String
  edited_topic   String?
  time_of_day    String
  score          Float          @default(0)
  posted         Boolean        @default(false)
  x_tweet_id     String?        // Null until successfully posted
  status         String         @default("PENDING") // PENDING, GENERATING, APPROVED, POSTED_CONFIRMED, RESOLVE_FAILED, ERROR
  intent_url     String?
  live_url       String?
  fingerprint    String?        @unique
  posted_at      DateTime?
  created_at     DateTime       @default(now())
  
  versions       TweetVersion[]
  feedbacks      Feedback[]
  engagements    Engagement[]
  outcome        TweetOutcome?
}

model TweetVersion {
  id            String   @id @default(uuid())
  tweet_id      String
  content       String
  version       Int      @default(1)
  critique      String?
  quality_score Float?
  created_at    DateTime @default(now())

  tweet         Tweet    @relation(fields: [tweet_id], references: [id])
}

model Feedback {
  id              String   @id @default(uuid())
  tweet_id        String
  feedback_text   String
  weighted_score  Float?
  created_at      DateTime @default(now())

  tweet           Tweet    @relation(fields: [tweet_id], references: [id])
}

model RetryQueue {
  id          String   @id @default(uuid())
  task_type   String   // e.g., "POST_TO_X", "SEND_EMAIL"
  payload     Json     // Payload of the task
  attempts    Int      @default(0)
  max_retries Int      @default(3)
  status      String   @default("PENDING") // PENDING, FAILED, COMPLETED
  last_error  String?
  process_after DateTime @default(now())
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Engagement {
  id          String   @id @default(uuid())
  tweet_id    String
  likes       Int      @default(0)
  retweets    Int      @default(0)
  impressions Int      @default(0)
  fetched_at  DateTime @default(now())

  tweet       Tweet    @relation(fields: [tweet_id], references: [id])
}

model TweetOutcome {
  id             String   @id @default(cuid())
  tweet_id       String   @unique
  tweet          Tweet    @relation(fields: [tweet_id], references: [id], onDelete: Cascade)
  outcome_score  Float
  tier           String
  peak_likes     Int
  peak_retweets  Int
  quality_score  Float?
  topic          String?
  time_of_day    String?
  day_of_week    String?
  computed_at    DateTime @default(now())

  @@index([tier, computed_at])
  @@index([time_of_day])
  @@index([day_of_week])
}

model PersonaProfile {
  id               String   @id @default(cuid())
  version          Int      @default(autoincrement())
  profile_text     String
  based_on_tweets  Int
  created_at       DateTime @default(now())
  is_active        Boolean  @default(true)
}

model LlmCallLog {
  id         String   @id @default(cuid())
  called_at  DateTime @default(now())
  model      String
  call_type  String

  @@index([called_at])
}
